# Normalize line endings so bundled plugin assets check out LF on every platform.
# CRLF in workflow .js files trips the Workflow approval dialog (CR = control char);
# CRLF in .sh files breaks the shebang. Force LF regardless of core.autocrlf.
* text=auto eol=lf
*.js   text eol=lf
*.py   text eol=lf
*.sh   text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.json text eol=lf

{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "sh -c 'PY=$(command -v python3 || command -v python); exec \"$PY\" -B \"${CLAUDE_PLUGIN_ROOT}/hooks/session_start.py\"'" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "sh -c 'PY=$(command -v python3 || command -v python); exec \"$PY\" -B \"${CLAUDE_PLUGIN_ROOT}/hooks/prompt_submit.py\"'" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "sh -c 'PY=$(command -v python3 || command -v python); exec \"$PY\" -B \"${CLAUDE_PLUGIN_ROOT}/hooks/stop.py\"'", "timeout": 30 }
        ]
      }
    ]
  }
}
